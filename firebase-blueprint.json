{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "preferences": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "products": {
      "title": "Product",
      "description": "Product listing details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "integer" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "avgRating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "sellerId"]
    },
    "orders": {
      "title": "Order",
      "description": "Transaction and order details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "reviews": {
      "title": "Review",
      "description": "Product reviews and ratings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "integer" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "notifications": {
      "title": "Notification",
      "description": "Real-time user notifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "read"]
    },
    "hero_content": {
      "title": "Hero Content",
      "description": "Dynamic hero section content for the home page",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "ctaText": { "type": "string" },
        "imageUrl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subtitle", "ctaText", "imageUrl"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    },
    "/products/{productId}": {
      "schema": "products",
      "description": "Product listing documents"
    },
    "/orders/{orderId}": {
      "schema": "orders",
      "description": "Order transaction documents"
    },
    "/reviews/{reviewId}": {
      "schema": "reviews",
      "description": "Product review documents"
    },
    "/notifications/{notificationId}": {
      "schema": "notifications",
      "description": "User notification documents"
    },
    "/settings/hero": {
      "schema": "hero_content",
      "description": "Global hero section settings"
    }
  }
}
